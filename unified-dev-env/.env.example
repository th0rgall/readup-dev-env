# GitHub credentials for cloning repos over HTTPS (see bootstrap-repos.sh).
# bootstrap-repos.sh injects these into each plain https://github.com/... URL as a
# user:password remote, so no SSH deploy key is needed.
#   GITHUB_USER  — your GitHub username, or "x-access-token" (the conventional
#                  username for a Personal Access Token). Defaults to x-access-token.
#   GITHUB_TOKEN — a GitHub Personal Access Token (PAT) with repo read access.
# Leave GITHUB_TOKEN empty to clone only public repos.
GITHUB_USER=
GITHUB_TOKEN=github_pat_...

# Host path to the Claude Code config directory mounted into the container.
CLAUDE_PATH=
